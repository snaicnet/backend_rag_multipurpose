{
  "family": "backend-rag-multipurpose",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "3072",
  "executionRoleArn": "arn:aws:iam::961341555117:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::961341555117:role/ecsTaskRole",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "ephemeralStorage": {
    "sizeInGiB": 30
  },
  "containerDefinitions": [
    {
      "name": "nginx",
      "image": "961341555117.dkr.ecr.ap-southeast-1.amazonaws.com/snaic_website/rag-nginx:latest",
      "essential": true,
      "cpu": 64,
      "memoryReservation": 128,
      "environment": [
        { "name": "NGINX_UPSTREAM_HOST", "value": "127.0.0.1" },
        { "name": "NGINX_UPSTREAM_PORT", "value": "8000" }
      ],
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "dependsOn": [
        {
          "containerName": "app",
          "condition": "HEALTHY"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://127.0.0.1/nginx-health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 15
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/backend-rag-multipurpose",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "nginx"
        }
      }
    },
    {
      "name": "app",
      "image": "961341555117.dkr.ecr.ap-southeast-1.amazonaws.com/snaic_website/rag-backend:latest",
      "essential": true,
      "cpu": 384,
      "memoryReservation": 768,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "APP_HOST", "value": "0.0.0.0" },
        { "name": "APP_PORT", "value": "8000" },
        { "name": "LOG_LEVEL", "value": "INFO" },
        { "name": "POSTGRES_DSN", "value": "postgresql://postgres:admin@127.0.0.1:5432/ragdb" },
        { "name": "REDIS_URL", "value": "redis://127.0.0.1:6379/0" },
        { "name": "QDRANT_URL", "value": "http://127.0.0.1:6333" },
        { "name": "OLLAMA_ENABLED", "value": "false" },
        { "name": "OPENAI_ENABLED", "value": "true" },
        { "name": "DEFAULT_LLM_PROVIDER", "value": "openai" },
        { "name": "DEFAULT_LLM_MODEL", "value": "gpt-4.1-mini" },
        { "name": "DEFAULT_EMBEDDING_PROFILE", "value": "openai_small_1536" },
        {
          "name": "EMBEDDING_PROFILES",
          "value": "{\"openai_small_1536\":{\"provider\":\"openai\",\"model\":\"text-embedding-3-small\",\"dimension\":1536}}"
        },
        { "name": "AUTH_ENABLED", "value": "true" },
        { "name": "AUTH_REQUIRE_HTTPS", "value": "false" },
        { "name": "CHAT_RATE_LIMIT_REQUESTS", "value": "20" },
        { "name": "CHAT_RATE_LIMIT_WINDOW_SECONDS", "value": "60" },
        { "name": "CHAT_DAILY_LIMIT_REQUESTS", "value": "1000" },
        { "name": "CHAT_MAX_MESSAGE_CHARS", "value": "4000" },
        { "name": "CHAT_MAX_INPUT_TOKENS", "value": "1000" },
        { "name": "CHAT_MAX_HISTORY_MESSAGES", "value": "8" },
        { "name": "CHAT_REPEATED_PROMPT_LOOKBACK", "value": "5" },
        { "name": "CHAT_MAX_CONTEXT_CHARS", "value": "8000" },
        { "name": "CHAT_MAX_CONTEXT_TOKENS", "value": "2500" },
        { "name": "CHAT_MAX_CONTEXT_CHUNK_CHARS", "value": "1800" },
        { "name": "CHAT_MIN_TOP_K", "value": "3" },
        { "name": "CHAT_MAX_TOP_K", "value": "8" },
        { "name": "CHAT_MAX_RESPONSE_CHARS", "value": "2000" },
        { "name": "CHAT_MAX_RESPONSE_TOKENS", "value": "700" }
      ],
      "secrets": [
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:ssm:ap-southeast-1:961341555117:parameter/backend-rag/OPENAI_API_KEY"
        },
        {
          "name": "AUTH_JWT_SECRET",
          "valueFrom": "arn:aws:ssm:ap-southeast-1:961341555117:parameter/backend-rag/AUTH_JWT_SECRET"
        },
        {
          "name": "AUTH_BOOTSTRAP_ADMIN_USERNAME",
          "valueFrom": "arn:aws:ssm:ap-southeast-1:961341555117:parameter/backend-rag/AUTH_BOOTSTRAP_ADMIN_USERNAME"
        },
        {
          "name": "AUTH_BOOTSTRAP_ADMIN_PASSWORD",
          "valueFrom": "arn:aws:ssm:ap-southeast-1:961341555117:parameter/backend-rag/AUTH_BOOTSTRAP_ADMIN_PASSWORD"
        }
      ],
      "dependsOn": [
        {
          "containerName": "postgres",
          "condition": "HEALTHY"
        },
        {
          "containerName": "redis",
          "condition": "HEALTHY"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health', timeout=5)\" || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 45
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/backend-rag-multipurpose",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "app"
        }
      }
    },
    {
      "name": "postgres",
      "image": "961341555117.dkr.ecr.ap-southeast-1.amazonaws.com/snaic_website/rag-postgres:latest",
      "essential": true,
      "cpu": 256,
      "memoryReservation": 1024,
      "portMappings": [
        {
          "containerPort": 5432,
          "hostPort": 5432,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "POSTGRES_DB", "value": "ragdb" },
        { "name": "POSTGRES_USER", "value": "postgres" },
        { "name": "POSTGRES_PASSWORD", "value": "admin" }
      ],
      "mountPoints": [
        {
          "sourceVolume": "postgres-data",
          "containerPath": "/var/lib/postgresql/data",
          "readOnly": false
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "pg_isready -U postgres -d ragdb || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 5,
        "startPeriod": 30
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/backend-rag-multipurpose",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "postgres"
        }
      }
    },
    {
      "name": "redis",
      "image": "redis:7.4-alpine",
      "essential": true,
      "cpu": 64,
      "memoryReservation": 256,
      "portMappings": [
        {
          "containerPort": 6379,
          "hostPort": 6379,
          "protocol": "tcp"
        }
      ],
      "command": ["redis-server", "--appendonly", "yes"],
      "mountPoints": [
        {
          "sourceVolume": "redis-data",
          "containerPath": "/data",
          "readOnly": false
        }
      ],
      "healthCheck": {
        "command": ["CMD", "redis-cli", "ping"],
        "interval": 30,
        "timeout": 5,
        "retries": 5,
        "startPeriod": 10
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/backend-rag-multipurpose",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "redis"
        }
      }
    },
    {
      "name": "qdrant",
      "image": "qdrant/qdrant:v1.14.1",
      "essential": true,
      "cpu": 64,
      "memoryReservation": 512,
      "portMappings": [
        {
          "containerPort": 6333,
          "hostPort": 6333,
          "protocol": "tcp"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "qdrant-data",
          "containerPath": "/qdrant/storage",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/backend-rag-multipurpose",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "qdrant"
        }
      }
    }
  ],
  "volumes": [
    {
      "name": "postgres-data"
    },
    {
      "name": "redis-data"
    },
    {
      "name": "qdrant-data"
    }
  ]
}
